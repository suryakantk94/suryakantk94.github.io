---
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/posts/', label: 'Posts' },
  { href: '/work/', label: 'Work' },
  { href: '/about/', label: 'About' },
  { href: '/now/', label: 'Now' },
];
const isCurrent = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="border-b border-[color:var(--color-rule)] mb-12">
  <div class="max-w-3xl mx-auto px-6 py-5 flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
    <a href="/" class="!text-[color:var(--color-ink)] !no-underline font-sans font-semibold tracking-tight text-base">
      Suryakant Kashyap
    </a>
    <nav class="flex flex-wrap gap-x-5 gap-y-1 font-sans text-sm">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class={
            'transition ' +
            (isCurrent(href)
              ? '!text-[color:var(--color-ink)] font-medium !no-underline'
              : '!text-[color:var(--color-ink-muted)] !no-underline hover:!text-[color:var(--color-accent)]')
          }
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
